<Window x:Class="GameControllerMapper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:local="clr-namespace:GameControllerMapper"
        mc:Ignorable="d"
        Title="Game Controller Mapper V1.0" Height="820" Width="1150"
        MinWidth="1150" MinHeight="820"
        Background="#1E1E1E" Foreground="White"
        KeyDown="Window_KeyDown">

    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBooleanConverter x:Key="InverseBool"/>
        <local:EqualityMultiConverter x:Key="EqualityConverter"/>

        <CollectionViewSource x:Key="GroupedKeys" Source="{Binding AllKeyOptions}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="Category"/>
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>

        <CollectionViewSource x:Key="BasicGroupedKeys" Source="{Binding BasicKeyOptions}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="Category"/>
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>

        <Style x:Key="BaseBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                BorderBrush="#777" BorderThickness="1" 
                                CornerRadius="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#555"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="2"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Bd" Property="Background" Value="#111"/>
                            </Trigger>

                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Value="True">
                                        <Condition.Binding>
                                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                                <Binding Path="DataContext.SelectedMapping.ControllerInput" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                            </MultiBinding>
                                        </Condition.Binding>
                                    </Condition>
                                    <Condition Binding="{Binding DataContext.IsRemappingActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="3"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#00FF00"/>
                            </MultiDataTrigger>

                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Value="True">
                                        <Condition.Binding>
                                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                                <Binding Path="DataContext.SelectedMapping.ControllerInput" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                            </MultiBinding>
                                        </Condition.Binding>
                                    </Condition>
                                    <Condition Binding="{Binding DataContext.SelectedMapping.TargetType, RelativeSource={RelativeSource AncestorType=Window}}" Value="{x:Static local:TargetDeviceType.CustomCombo}"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="Yellow"/>
                            </MultiDataTrigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#F2000000"/>
            <Setter Property="BorderBrush" Value="#4DB8FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="IsHitTestVisible" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#4DB8FF" Opacity="0.8"/>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}">
                    <DataTrigger.Value>
                        <sys:Boolean>True</sys:Boolean>
                    </DataTrigger.Value>
                    <Setter Property="Background" Value="#CCFFFFFF"/>
                    <Setter Property="BorderBrush" Value="#0000AA"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="White" Opacity="1"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4DB8FF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CustomTabItemStyle" TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Background="#333" Padding="20,10" CornerRadius="5,5,0,0">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.FontSize="14" TextElement.FontWeight="Bold"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#444"/>
                                <Setter Property="Foreground" Value="#4DB8FF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="#AAA"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkGroupBox" TargetType="GroupBox">
            <Setter Property="Foreground" Value="#4DB8FF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" BorderThickness="1" BorderBrush="#555" Background="#2D2D30" CornerRadius="3,3,0,0" Padding="5,2">
                                <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"/>
                            </Border>
                            <Border Grid.Row="1" BorderThickness="1,0,1,1" BorderBrush="#555" Background="Transparent" CornerRadius="0,0,3,3" Padding="{TemplateBinding Padding}">
                                <ContentPresenter />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NeonBase" TargetType="TextBlock">
            <Setter Property="FontSize" Value="30"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.8"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NeonRed" TargetType="TextBlock" BasedOn="{StaticResource NeonBase}">
            <Setter Property="Foreground" Value="#FF5555"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Red" BlurRadius="15" ShadowDepth="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.3" To="1.0" Duration="0:0:0.8"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="NeonGreen" TargetType="TextBlock" BasedOn="{StaticResource NeonBase}">
            <Setter Property="Foreground" Value="#55FF55"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Lime" BlurRadius="15" ShadowDepth="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.3" To="1.0" Duration="0:0:1.2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="NeonBlue" TargetType="TextBlock" BasedOn="{StaticResource NeonBase}">
            <Setter Property="Foreground" Value="#55FFFF"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Cyan" BlurRadius="15" ShadowDepth="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.3" To="1.0" Duration="0:0:1.0"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="NeonPurple" TargetType="TextBlock" BasedOn="{StaticResource NeonBase}">
            <Setter Property="Foreground" Value="#FF55FF"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Magenta" BlurRadius="15" ShadowDepth="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.3" To="1.0" Duration="0:0:1.5"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,15,20,0" Panel.ZIndex="100">
            <Run Text="Programing by " Foreground="#AAA" FontSize="14"/>
            <Hyperlink Command="{Binding OpenUrlCommand}" CommandParameter="https://www.facebook.com/su.wen.142/" TextDecorations="None">
                <Run Text="SuperWen" Foreground="#4DB8FF" FontWeight="Bold" FontSize="14"/>
            </Hyperlink>
        </TextBlock>

        <TabControl Grid.Row="0" SelectedIndex="{Binding SelectedTabIndex}" Background="Transparent" BorderThickness="0">
            <TabItem Header="📖 使用說明" 
                     Style="{StaticResource CustomTabItemStyle}"
                     IsEnabled="{Binding IsRemappingActive, Converter={StaticResource InverseBool}}">
                <Grid Margin="30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,20,0" VerticalAlignment="Center">
                        <TextBlock Text="如何使用 Game Controller Mapper" FontSize="28" FontWeight="Bold" Foreground="#4DB8FF" Margin="0,0,0,30"/>

                        <TextBlock Text="1. 選擇按鍵" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                        <TextBlock Text="在手把圖示上，點選您想要修改的按鈕。選取後，右側面板會顯示該按鈕的當前設定。" FontSize="16" Foreground="#CCC" TextWrapping="Wrap" LineHeight="24"/>

                        <TextBlock Text="2. 設定功能" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,30,0,10"/>
                        <TextBlock Text="您可以透過以下方式設定功能：" FontSize="16" Foreground="#CCC" TextWrapping="Wrap" LineHeight="24"/>
                        <StackPanel Margin="10,5,0,0">
                            <TextBlock Text="• 滑鼠功能：直接點選左鍵、右鍵或滾輪。" FontSize="16" Foreground="#CCC" Margin="0,3"/>
                            <TextBlock Text="• 下拉選單：直接選擇特殊的組合鍵或功能。" FontSize="16" Foreground="#CCC" Margin="0,3"/>
                            <TextBlock Text="• 自定義組合鍵：可自訂鍵盤五個按鍵，作為快捷鍵。" FontSize="16" Foreground="#CCC" Margin="0,3"/>
                        </StackPanel>

                        <TextBlock Text="3. 啟動轉換" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,30,0,10"/>
                        <TextBlock Text="設定完成後，點擊右下角的「啟動手把功能轉換」綠色按鈕即可開始使用。" FontSize="16" Foreground="#CCC" TextWrapping="Wrap" LineHeight="24"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">

                        <Border Background="#331111" BorderBrush="#FF5555" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                            <Border.Effect>
                                <DropShadowEffect Color="Red" BlurRadius="10" Opacity="0.2" ShadowDepth="0"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="⛔ 用途限制與免責聲明" FontSize="20" FontWeight="Bold" Foreground="#FF5555" Margin="0,0,0,10"/>
                                <TextBlock Text="本軟體定位為「生產力輔助工具」" FontSize="18" Foreground="White" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBlock Text="(如：繪圖快捷鍵、影片剪輯、單機操作輔助)。" FontSize="16" Foreground="#DDD" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                <TextBlock Text="嚴禁於線上競技遊戲中使用！" FontSize="18" FontWeight="Bold" Foreground="#FF5555" TextWrapping="Wrap" Margin="0,5"/>
                                <TextBlock Text="極高機率被防作弊系統判定為非法外掛，導致帳號永久封鎖。作者不承擔任何帳號損失責任。" FontSize="16" Foreground="#DDD" TextWrapping="Wrap" LineHeight="22"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#332200" BorderBrush="#FFCC00" BorderThickness="1" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="⚠️ 本功能失效的可能原因" FontSize="20" FontWeight="Bold" Foreground="#FFCC00" Margin="0,0,0,10"/>
                                <TextBlock Text="若在部分軟體中按鍵無反應，可能是以下機制導致：" FontSize="16" Foreground="White" FontWeight="Bold" Margin="0,0,0,5"/>

                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="1." Foreground="#FFCC00" FontSize="16" Margin="0,0,5,0"/>
                                    <TextBlock Grid.Column="1" Text="權限不足：目標軟體以管理員執行時，本程式也需「以系統管理員身分執行」才能控制。" FontSize="16" Foreground="#DDD" TextWrapping="Wrap" Margin="0,0,0,5"/>
                                </Grid>

                                <Grid Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="2." Foreground="#FFCC00" FontSize="16" Margin="0,0,5,0"/>
                                    <TextBlock Grid.Column="1" Text="輸入模式衝突：部分程式使用 RawInput 或 DirectInput 獨佔輸入，會繞過 Windows 模擬層。" FontSize="16" Foreground="#DDD" TextWrapping="Wrap" Margin="0,0,0,5"/>
                                </Grid>

                                <Grid Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="3." Foreground="#FFCC00" FontSize="16" Margin="0,0,5,0"/>
                                    <TextBlock Grid.Column="1" Text="安全性阻擋：防毒軟體、資安軟體或核心級防護，可能會主動攔截本工具虛擬鍵盤訊號。" FontSize="16" Foreground="#DDD" TextWrapping="Wrap"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="🎮 手把設定" Style="{StaticResource CustomTabItemStyle}">
                <Border BorderThickness="0" Margin="5">
                    <Grid Background="#2D2D30">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.5*"/>
                            <ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Viewbox Grid.Row="0" Stretch="Uniform" Margin="0">
                                <Canvas Width="420" Height="400" Background="Transparent">
                                    <Canvas x:Name="ControllerGroup_Xbox">
                                        <Canvas.RenderTransform>
                                            <TranslateTransform X="-60" Y="0"/>
                                        </Canvas.RenderTransform>

                                        <Path Stroke="#666" StrokeThickness="2" Fill="Transparent" HorizontalAlignment="Center" Stretch="Fill" VerticalAlignment="Top" Width="325" Canvas.Left="110.51" Canvas.Top="15.5">
                                            <Path.Data>
                                                <GeometryGroup>
                                                    <PathGeometry Figures="M 120,55 Q 115,55 115,70 L 115,120 Q 115,135 130,135 L 180,135 Q 195,135 195,120 L 195,70 Q 195,55 180,55 Z"/>
                                                    <PathGeometry Figures="M 355,55 Q 340,55 340,70 L 340,120 Q 340,135 355,135 L 405,135 Q 420,135 420,120 L 420,70 Q 420,55 405,55 Z"/>
                                                    <PathGeometry Figures="M 195,95 L 340,95"/>
                                                </GeometryGroup>
                                            </Path.Data>
                                        </Path>
                                        <Path Stroke="#666" StrokeThickness="2" Fill="Transparent" HorizontalAlignment="Center" Stretch="Fill" VerticalAlignment="Top" Width="411" Height="297" Canvas.Left="66.089" Canvas.Top="100">
                                            <Path.Data>
                                                <PathGeometry Figures="M 266,140 C 220,140 110,150 95,215 C 85,265 90,325 120,385 Q 145,415 170,365 Q 185,335 266,315 Q 347,335 362,365 Q 387,415 412,385 C 442,325 447,265 437,215 C 422,150 312,140 266,140 Z"/>
                                            </Path.Data>
                                        </Path>

                                        <Button Content="LT" Tag="5" Style="{StaticResource BaseBtnStyle}" Width="60" Height="30" Canvas.Left="125" Canvas.Top="21" Command="{Binding SelectMappingCommand}" CommandParameter="TriggerLeft" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                                        <Button Content="RT" Tag="5" Style="{StaticResource BaseBtnStyle}" Width="60" Height="30" Canvas.Left="362" Canvas.Top="21" Command="{Binding SelectMappingCommand}" CommandParameter="TriggerRight" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                                        <Button Content="LB" Tag="5" Style="{StaticResource BaseBtnStyle}" Width="60" Height="30" Canvas.Left="125" Canvas.Top="61" Command="{Binding SelectMappingCommand}" CommandParameter="ShoulderLeft" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                                        <Button Content="RB" Tag="5" Style="{StaticResource BaseBtnStyle}" Width="60" Height="30" Canvas.Left="362" Canvas.Top="61" Command="{Binding SelectMappingCommand}" CommandParameter="ShoulderRight" HorizontalAlignment="Center" VerticalAlignment="Top"/>

                                        <Button Content="L-Move" Tag="3" Style="{StaticResource BaseBtnStyle}" Width="60" Height="25" Canvas.Left="120" Canvas.Top="152" Command="{Binding SelectMappingCommand}" CommandParameter="StickLeftMove" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                                        <Button Content="L3" Tag="20" Style="{StaticResource BaseBtnStyle}" Width="40" Height="40" Canvas.Left="130" Canvas.Top="182" Command="{Binding SelectMappingCommand}" CommandParameter="StickLeftClick" HorizontalAlignment="Center" VerticalAlignment="Top"/>

                                        <Button Content="▲" Tag="3" Style="{StaticResource BaseBtnStyle}" Width="30" Height="30" Canvas.Left="174" Canvas.Top="234" Command="{Binding SelectMappingCommand}" CommandParameter="DPadUp" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                                        <Button Content="▼" Tag="3" Style="{StaticResource BaseBtnStyle}" Width="30" Height="30" Canvas.Left="174" Canvas.Top="294" Command="{Binding SelectMappingCommand}" CommandParameter="DPadDown" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                                        <Button Content="◀" Tag="3" Style="{StaticResource BaseBtnStyle}" Width="30" Height="30" Canvas.Left="144" Canvas.Top="264" Command="{Binding SelectMappingCommand}" CommandParameter="DPadLeft" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                                        <Button Content="▶" Tag="3" Style="{StaticResource BaseBtnStyle}" Width="30" Height="30" Canvas.Left="204" Canvas.Top="264" Command="{Binding SelectMappingCommand}" CommandParameter="DPadRight" HorizontalAlignment="Center" VerticalAlignment="Top"/>

                                        <Button Content="Back" Tag="5" Style="{StaticResource BaseBtnStyle}" Width="50" Height="25" Canvas.Left="213" Canvas.Top="130" Command="{Binding SelectMappingCommand}" CommandParameter="Back" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                                        <Button Content="Start" Tag="5" Style="{StaticResource BaseBtnStyle}" Width="50" Height="25" Canvas.Left="283" Canvas.Top="130" Command="{Binding SelectMappingCommand}" CommandParameter="Start" HorizontalAlignment="Center" VerticalAlignment="Top"/>

                                        <Button Content="Y" Tag="20" Style="{StaticResource BaseBtnStyle}" Width="40" Height="40" Canvas.Left="380" Canvas.Top="127" Command="{Binding SelectMappingCommand}" CommandParameter="ButtonY" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                                        <Button Content="X" Tag="20" Style="{StaticResource BaseBtnStyle}" Width="40" Height="40" Canvas.Left="340" Canvas.Top="167" Command="{Binding SelectMappingCommand}" CommandParameter="ButtonX" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                                        <Button Content="B" Tag="20" Style="{StaticResource BaseBtnStyle}" Width="40" Height="40" Canvas.Left="420" Canvas.Top="167" Command="{Binding SelectMappingCommand}" CommandParameter="ButtonB" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                                        <Button Content="A" Tag="20" Style="{StaticResource BaseBtnStyle}" Width="40" Height="40" Canvas.Left="380" Canvas.Top="207" Command="{Binding SelectMappingCommand}" CommandParameter="ButtonA" HorizontalAlignment="Center" VerticalAlignment="Top"/>

                                        <Button Content="R-Move" Tag="3" Style="{StaticResource BaseBtnStyle}" Width="60" Height="25" Canvas.Left="324" Canvas.Top="254" Command="{Binding SelectMappingCommand}" CommandParameter="StickRightMove" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                                        <Button Content="R3" Tag="20" Style="{StaticResource BaseBtnStyle}" Width="40" Height="40" Canvas.Left="334" Canvas.Top="284" Command="{Binding SelectMappingCommand}" CommandParameter="StickRightClick" HorizontalAlignment="Center" VerticalAlignment="Top"/>

                                        <Border Canvas.Left="0" Canvas.Top="0" Width="600" Height="500" Margin="-50,-30,0,0" Background="#A0000000" IsHitTestVisible="False" Visibility="{Binding IsRemappingActive, Converter={StaticResource BoolToVis}}"/>

                                        <Border Style="{StaticResource StatusBadgeStyle}" Width="90" Height="20" Canvas.Left="110" Canvas.Top="26" Tag="{Binding Pressed[TriggerLeft]}" Visibility="{Binding IsRemappingActive, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Style="{StaticResource StatusTextStyle}" Text="{Binding [TriggerLeft]}"/>
                                        </Border>
                                        <Border Style="{StaticResource StatusBadgeStyle}" Width="90" Height="20" Canvas.Left="346" Canvas.Top="26" Tag="{Binding Pressed[TriggerRight]}" Visibility="{Binding IsRemappingActive, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Style="{StaticResource StatusTextStyle}" Text="{Binding [TriggerRight]}"/>
                                        </Border>
                                        <Border Style="{StaticResource StatusBadgeStyle}" Width="90" Height="20" Canvas.Left="110" Canvas.Top="65" Tag="{Binding Pressed[ShoulderLeft]}" Visibility="{Binding IsRemappingActive, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Style="{StaticResource StatusTextStyle}" Text="{Binding [ShoulderLeft]}"/>
                                        </Border>
                                        <Border Style="{StaticResource StatusBadgeStyle}" Width="90" Height="20" Canvas.Left="346" Canvas.Top="65" Tag="{Binding Pressed[ShoulderRight]}" Visibility="{Binding IsRemappingActive, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Style="{StaticResource StatusTextStyle}" Text="{Binding [ShoulderRight]}"/>
                                        </Border>
                                        <Border Style="{StaticResource StatusBadgeStyle}" Width="90" Height="20" Canvas.Left="105" Canvas.Top="154" Tag="{Binding Pressed[StickLeftMove]}" Visibility="{Binding IsRemappingActive, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Style="{StaticResource StatusTextStyle}" Text="{Binding [StickLeftMove]}"/>
                                        </Border>
                                        <Border Style="{StaticResource StatusBadgeStyle}" Width="90" Height="20" Canvas.Left="105" Canvas.Top="191" Tag="{Binding Pressed[StickLeftClick]}" Visibility="{Binding IsRemappingActive, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Style="{StaticResource StatusTextStyle}" Text="{Binding [StickLeftClick]}"/>
