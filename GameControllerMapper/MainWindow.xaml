                                        <Border Style="{StaticResource StatusBadgeStyle}" Width="90" Height="20" Canvas.Left="144" Canvas.Top="238" Tag="{Binding Pressed[DPadUp]}" Visibility="{Binding IsRemappingActive, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Style="{StaticResource StatusTextStyle}" Text="{Binding [DPadUp]}"/>
                                        </Border>
                                        <Border Style="{StaticResource StatusBadgeStyle}" Width="90" Height="20" Canvas.Left="144" Canvas.Top="299" Tag="{Binding Pressed[DPadDown]}" Visibility="{Binding IsRemappingActive, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Style="{StaticResource StatusTextStyle}" Text="{Binding [DPadDown]}"/>
                                        </Border>
                                        <Border Style="{StaticResource StatusBadgeStyle}" Width="75" Height="20" Canvas.Left="113" Canvas.Top="269" Tag="{Binding Pressed[DPadLeft]}" Visibility="{Binding IsRemappingActive, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Style="{StaticResource StatusTextStyle}" Text="{Binding [DPadLeft]}"/>
                                        </Border>
                                        <Border Style="{StaticResource StatusBadgeStyle}" Width="75" Height="20" Canvas.Left="192" Canvas.Top="269" Tag="{Binding Pressed[DPadRight]}" Visibility="{Binding IsRemappingActive, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Style="{StaticResource StatusTextStyle}" Text="{Binding [DPadRight]}"/>
                                        </Border>
                                        <Border Style="{StaticResource StatusBadgeStyle}" Width="80" Height="20" Canvas.Left="190" Canvas.Top="132" Tag="{Binding Pressed[Back]}" Visibility="{Binding IsRemappingActive, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Style="{StaticResource StatusTextStyle}" Text="{Binding [Back]}"/>
                                        </Border>
                                        <Border Style="{StaticResource StatusBadgeStyle}" Width="80" Height="20" Canvas.Left="273" Canvas.Top="132" Tag="{Binding Pressed[Start]}" Visibility="{Binding IsRemappingActive, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Style="{StaticResource StatusTextStyle}" Text="{Binding [Start]}"/>
                                        </Border>
                                        <Border Style="{StaticResource StatusBadgeStyle}" Width="90" Height="20" Canvas.Left="355" Canvas.Top="137" Tag="{Binding Pressed[ButtonY]}" Visibility="{Binding IsRemappingActive, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Style="{StaticResource StatusTextStyle}" Text="{Binding [ButtonY]}"/>
                                        </Border>
                                        <Border Style="{StaticResource StatusBadgeStyle}" Width="80" Height="20" Canvas.Left="318" Canvas.Top="177" Tag="{Binding Pressed[ButtonX]}" Visibility="{Binding IsRemappingActive, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Style="{StaticResource StatusTextStyle}" Text="{Binding [ButtonX]}"/>
                                        </Border>
                                        <Border Style="{StaticResource StatusBadgeStyle}" Width="80" Height="20" Canvas.Left="402" Canvas.Top="177" Tag="{Binding Pressed[ButtonB]}" Visibility="{Binding IsRemappingActive, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Style="{StaticResource StatusTextStyle}" Text="{Binding [ButtonB]}"/>
                                        </Border>
                                        <Border Style="{StaticResource StatusBadgeStyle}" Width="90" Height="20" Canvas.Left="355" Canvas.Top="217" Tag="{Binding Pressed[ButtonA]}" Visibility="{Binding IsRemappingActive, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Style="{StaticResource StatusTextStyle}" Text="{Binding [ButtonA]}"/>
                                        </Border>
                                        <Border Style="{StaticResource StatusBadgeStyle}" Width="90" Height="20" Canvas.Left="310" Canvas.Top="256" Tag="{Binding Pressed[StickRightMove]}" Visibility="{Binding IsRemappingActive, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Style="{StaticResource StatusTextStyle}" Text="{Binding [StickRightMove]}"/>
                                        </Border>
                                        <Border Style="{StaticResource StatusBadgeStyle}" Width="90" Height="20" Canvas.Left="310" Canvas.Top="293" Tag="{Binding Pressed[StickRightClick]}" Visibility="{Binding IsRemappingActive, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Style="{StaticResource StatusTextStyle}" Text="{Binding [StickRightClick]}"/>
