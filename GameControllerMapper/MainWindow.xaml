                                    </Canvas>
                                </Canvas>
                            </Viewbox>
                        </Grid>

                        <Grid Grid.Column="1" Background="#333">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Grid.RowSpan="3" Background="#D81E1E1E" Panel.ZIndex="10" 
                                    IsHitTestVisible="True" 
                                    Visibility="{Binding IsRemappingActive, Converter={StaticResource BoolToVis}}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="🔒 運作中" Foreground="#00FF00" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10">
                                        <TextBlock.Effect>
                                            <DropShadowEffect Color="#00FF00" BlurRadius="15" ShadowDepth="0"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                    <TextBlock Text="請先停止功能轉換才能修改設定" Foreground="#AAA" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Row="0" Margin="10,10,10,0">
                                <TextBlock Text="{Binding SelectedMapping.ControllerInput, StringFormat='正在設定: {0}'}" Foreground="#4DB8FF" FontSize="20" FontWeight="Bold" Margin="0,5"/>
                            </StackPanel>

                            <Grid Grid.Row="1">
                                <GroupBox Header="按鍵對應設定" Style="{StaticResource DarkGroupBox}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <ListView x:Name="ConfigList" Grid.Row="0" ItemsSource="{Binding Config.Mappings}" SelectedItem="{Binding SelectedMapping}" 
                                                  Background="#2D2D30" BorderThickness="0" HorizontalContentAlignment="Stretch" Margin="0,0,0,5"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="ConfigList_SelectionChanged">
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="#444" BorderThickness="0,0,0,1" Padding="5">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="100"/>
                                                                <ColumnDefinition Width="30"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding ControllerInput}" Grid.Column="0" Foreground="White" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="➡" Grid.Column="1" Foreground="Gray" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding DisplayName}" Grid.Column="2" FontWeight="Bold" VerticalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#00FF00"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding TargetType}" Value="CustomCombo">
                                                                                <Setter Property="Foreground" Value="Yellow"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>

                                        <StackPanel Grid.Row="1">

                                            <Grid>
                                                <StackPanel>
                                                    <Grid Margin="0,10,0,0">
                                                        <TextBlock Text="設定功能:" Foreground="Gray" Margin="0,5,0,2"/>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                            <Button Content="無" Command="{Binding SetMouseFunctionCommand}" CommandParameter="None" Width="30" Background="#444"/>
                                                            <Button Content="左鍵" Command="{Binding SetMouseFunctionCommand}" CommandParameter="Left" Width="45" Background="#444"/>
                                                            <Button Content="中鍵" Command="{Binding SetMouseFunctionCommand}" CommandParameter="Middle" Width="40" Background="#444"/>
                                                            <Button Content="右鍵" Command="{Binding SetMouseFunctionCommand}" CommandParameter="Right" Width="45" Background="#444"/>
                                                            <Button Content="滾輪上" Command="{Binding SetMouseFunctionCommand}" CommandParameter="ScrollUp" Width="55" Background="#444"/>
                                                            <Button Content="滾輪下" Command="{Binding SetMouseFunctionCommand}" CommandParameter="ScrollDown" Width="55" Background="#444"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <Grid Margin="0,10,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="指定按鍵:" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,10,0"/>

                                                        <ComboBox Grid.Column="1" ItemsSource="{Binding Source={StaticResource GroupedKeys}}" IsSynchronizedWithCurrentItem="False" DisplayMemberPath="Name" SelectedValuePath="Code" SelectedValue="{Binding SelectedMapping.KeyCode}" Height="30" FontSize="14" Margin="7,0,0,0">
                                                            <ComboBox.GroupStyle>
                                                                <GroupStyle>
                                                                    <GroupStyle.HeaderTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#4DB8FF" Background="#222" Padding="5"/>
                                                                        </DataTemplate>
                                                                    </GroupStyle.HeaderTemplate>
                                                                </GroupStyle>
                                                            </ComboBox.GroupStyle>
                                                        </ComboBox>
                                                    </Grid>
                                                    <Button Content="➕ 加入自定義組合鍵..." Command="{Binding OpenComboCreatorCommand}" Background="#335588" Height="35" FontSize="14" Margin="76,5,0,5" Foreground="White" FontWeight="Bold"/>
                                                </StackPanel>

                                                <Border Background="#A8111111" CornerRadius="4" IsHitTestVisible="True" Margin="0,-5,0,0"
                                                        Visibility="{Binding SelectedMapping.IsStickMove, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="搖桿模式已鎖定此區塊" Foreground="#AAA" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>

                                            <StackPanel Margin="0,10,0,0" Visibility="{Binding SelectedMapping.IsStickMove, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="搖桿靈敏度:" Foreground="Gray" Margin="0,0,0,5"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="30"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Slider Value="{Binding SelectedMapping.Sensitivity}" Minimum="1" Maximum="50"/>
                                                    <TextBlock Text="{Binding SelectedMapping.Sensitivity, StringFormat=N1}" Grid.Column="1" Foreground="Yellow" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                                </Grid>
                                            </StackPanel>

                                        </StackPanel>
                                    </Grid>
                                </GroupBox>
                            </Grid>

                            <Grid Grid.Row="2">
                                <GroupBox Header="設定檔管理" Style="{StaticResource DarkGroupBox}">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Content="儲存設定" Grid.Column="0" Command="{Binding SaveProfileCommand}"/>
                                            <Button Content="讀取設定" Grid.Column="1" Command="{Binding LoadProfileFromFileCommand}"/>
                                            <Button Content="開啟資料夾" Grid.Column="2" Command="{Binding OpenProfileFolderCommand}"/>
                                        </Grid>
                                        <Button Content="還原預設值" Command="{Binding ResetProfileCommand}" Background="#555" Margin="0,5,0,0"/>
                                        <Button Content="🔧 產生預設程式碼 (DevMode)" Command="{Binding GenerateCodeCommand}" Background="#883333" Margin="0,5,0,0" Visibility="{Binding IsDevMode, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                </GroupBox>
                            </Grid>

                            <StackPanel Grid.Row="3" Margin="10,0,10,10">
                                <Button Command="{Binding ToggleServiceCommand}" Height="45" FontSize="18" FontWeight="Bold">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRemappingActive}" Value="False">
                                                    <Setter Property="Background" Value="#008000"/>
                                                    <Setter Property="Content" Value="▶️ 啟動手把功能轉換"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsRemappingActive}" Value="True">
                                                    <Setter Property="Background" Value="#B00"/>
                                                    <Setter Property="Content" Value="⏹ 停止功能轉換"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="💰 贊助斗內" Style="{StaticResource CustomTabItemStyle}" IsEnabled="{Binding IsRemappingActive, Converter={StaticResource InverseBool}}">
                <Grid Background="#111" Visibility="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TabItem}, Converter={StaticResource BoolToVis}}">
                    <Grid VerticalAlignment="Top" Margin="0,20,0,0" ClipToBounds="True">
                        <TextBlock Text="感謝您的支持！您的贊助是我們開發的動力！ ❤️ Thank you for your support! ❤️" FontSize="20" Foreground="#555" HorizontalAlignment="Center">
                            <TextBlock.RenderTransform>
                                <TranslateTransform X="0"/>
                            </TextBlock.RenderTransform>
                            <TextBlock.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" From="-300" To="300" Duration="0:0:5"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </TextBlock.Triggers>
                        </TextBlock>
                    </Grid>
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="✨" Style="{StaticResource NeonBlue}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="✨" Style="{StaticResource NeonRed}"/>
                            <TextBlock Text="💡" Style="{StaticResource NeonGreen}"/>
                            <TextBlock Text="✨" Style="{StaticResource NeonBlue}"/>
                            <TextBlock Text="💡" Style="{StaticResource NeonPurple}"/>
                            <TextBlock Text="✨" Style="{StaticResource NeonRed}"/>
                        </StackPanel>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="💡" Style="{StaticResource NeonGreen}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="1" Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="💡" Style="{StaticResource NeonBlue}"/>
                            <TextBlock Text="✨" Style="{StaticResource NeonRed}"/>
                            <TextBlock Text="💡" Style="{StaticResource NeonGreen}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="✨" Style="{StaticResource NeonGreen}"/>
                            <TextBlock Text="💡" Style="{StaticResource NeonPurple}"/>
                            <TextBlock Text="✨" Style="{StaticResource NeonBlue}"/>
                        </StackPanel>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="💡" Style="{StaticResource NeonRed}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="💡" Style="{StaticResource NeonPurple}"/>
                            <TextBlock Text="✨" Style="{StaticResource NeonBlue}"/>
                            <TextBlock Text="💡" Style="{StaticResource NeonGreen}"/>
                            <TextBlock Text="✨" Style="{StaticResource NeonRed}"/>
                            <TextBlock Text="💡" Style="{StaticResource NeonPurple}"/>
                        </StackPanel>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="✨" Style="{StaticResource NeonPurple}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="30">
                            <TextBlock Text="感謝乾爹乾媽贊助！" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center" Foreground="White">
                                <TextBlock.Effect>
                                    <DropShadowEffect x:Name="NeonGlow" BlurRadius="20" ShadowDepth="0" Color="#FF00FF"/>
                                </TextBlock.Effect>
                                <TextBlock.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <ColorAnimation Storyboard.TargetName="NeonGlow" Storyboard.TargetProperty="Color" From="#FF00FF" To="#00FFFF" Duration="0:0:2"/>
                                                <DoubleAnimation Storyboard.TargetName="NeonGlow" Storyboard.TargetProperty="BlurRadius" From="10" To="30" Duration="0:0:1"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </TextBlock.Triggers>
                            </TextBlock>
                            <TextBlock Text="覺得好用的話，請賞杯咖啡吧 ☕" FontSize="24" Foreground="#AAA" HorizontalAlignment="Center" Margin="0,20"/>
                            <Button Content="👉 前往 PayPal 斗內 👈" Command="{Binding OpenUrlCommand}" CommandParameter="https://www.paypal.com/ncp/payment/U27XGJQN9GKCJ" FontSize="28" FontWeight="Bold" Background="#FFC439" Foreground="Black" Padding="30,15" Margin="0,30" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="10"/>
                                    </Style>
                                </Button.Resources>
                                <Button.RenderTransform>
                                    <ScaleTransform x:Name="BtnScale" ScaleX="1" ScaleY="1"/>
                                </Button.RenderTransform>
                                <Button.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetName="BtnScale" Storyboard.TargetProperty="ScaleX" From="1.0" To="1.1" Duration="0:0:0.8"/>
                                                <DoubleAnimation Storyboard.TargetName="BtnScale" Storyboard.TargetProperty="ScaleY" From="1.0" To="1.1" Duration="0:0:0.8"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Button.Triggers>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.RowSpan="2" Background="#DD000000" Visibility="{Binding IsComboCreatorOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="999">
            <Border Background="#252526" BorderBrush="#4DB8FF" BorderThickness="2" CornerRadius="10" Width="720" Height="260" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Margin="20">
                    <TextBlock Text="自定義組合鍵：" FontSize="22" FontWeight="Bold" Foreground="#4DB8FF" Margin="0,0,0,30"/>
                    <TextBlock Text="💡 提示：windows系統安全限制，無法使用 Ctrl+Alt+Del，若需呼叫工作管理員請改用 Ctrl+Shift+Esc" FontSize="14" Foreground="#FFCC00" Margin="0,0,0,25" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,30">
                        <ComboBox ItemsSource="{Binding Source={StaticResource BasicGroupedKeys}}" IsSynchronizedWithCurrentItem="False" DisplayMemberPath="Name" SelectedValuePath="Code" SelectedValue="{Binding ComboKey1}" Width="100" Height="30" FontSize="14"/>
                        <TextBlock Text="+" Foreground="White" FontSize="20" FontWeight="Bold" Margin="8,0" VerticalAlignment="Center"/>
                        <ComboBox ItemsSource="{Binding Source={StaticResource BasicGroupedKeys}}" IsSynchronizedWithCurrentItem="False" DisplayMemberPath="Name" SelectedValuePath="Code" SelectedValue="{Binding ComboKey2}" Width="100" Height="30" FontSize="14"/>
                        <TextBlock Text="+" Foreground="White" FontSize="20" FontWeight="Bold" Margin="8,0" VerticalAlignment="Center"/>
                        <ComboBox ItemsSource="{Binding Source={StaticResource BasicGroupedKeys}}" IsSynchronizedWithCurrentItem="False" DisplayMemberPath="Name" SelectedValuePath="Code" SelectedValue="{Binding ComboKey3}" Width="100" Height="30" FontSize="14"/>
                        <TextBlock Text="+" Foreground="White" FontSize="20" FontWeight="Bold" Margin="8,0" VerticalAlignment="Center"/>
                        <ComboBox ItemsSource="{Binding Source={StaticResource BasicGroupedKeys}}" IsSynchronizedWithCurrentItem="False" DisplayMemberPath="Name" SelectedValuePath="Code" SelectedValue="{Binding ComboKey4}" Width="100" Height="30" FontSize="14"/>
                        <TextBlock Text="+" Foreground="White" FontSize="20" FontWeight="Bold" Margin="8,0" VerticalAlignment="Center"/>
                        <ComboBox ItemsSource="{Binding Source={StaticResource BasicGroupedKeys}}" IsSynchronizedWithCurrentItem="False" DisplayMemberPath="Name" SelectedValuePath="Code" SelectedValue="{Binding ComboKey5}" Width="100" Height="30" FontSize="14"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="取消" Command="{Binding CloseComboCreatorCommand}" Background="#555" Foreground="White" FontWeight="Bold" Width="100" Height="35" Margin="0,0,20,0"/>
                        <Button Content="確定" Command="{Binding SaveNewComboCommand}" Background="#007ACC" Foreground="White" FontWeight="Bold" Width="100" Height="35"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <StatusBar Grid.Row="1" Background="#007ACC" Foreground="White" Padding="10,5">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" FontSize="14" FontWeight="Bold"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>